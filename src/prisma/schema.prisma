generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  password     String
  createdAt    DateTime      @default(now())
  testimonials Testimonial[]
}

model Project {
  id           Int      @id @default(autoincrement())
  title        String
  slug         String   @unique
  description  String
  technologies String
  image        String?
  githubUrl    String?
  demoUrl      String?
  createdAt    DateTime @default(now())
}

model Testimonial {
  id        Int      @id @default(autoincrement())
  author    String
  message   String
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}